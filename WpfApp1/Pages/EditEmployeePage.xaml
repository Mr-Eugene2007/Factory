<Page x:Class="WpfApp1.Pages.EditEmployeePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
       Title="Добавление/редактирование сотрудника">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Редактирование сотрудника" 
                   FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Основная форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Тип сотрудника -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип сотрудника:" 
                           Margin="5" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="5">
                    <RadioButton x:Name="rbSupplier" 
                                 Content="Поставщик" 
                                 IsChecked="{Binding IsSupplier}"
                                 GroupName="EmployeeType"
                                 Margin="5"
                                 VerticalAlignment="Center" Checked="rbSupplier_Checked"/>
                    <RadioButton x:Name="rbCustomer" 
                                 Content="Клиент" 
                                 IsChecked="{Binding IsCustomer}"
                                 GroupName="EmployeeType"
                                 Margin="5"
                                 VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Фамилия -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Фамилия:" 
                           Margin="5" VerticalAlignment="Center"/>
                <TextBox x:Name="txtLastName" Grid.Row="1" Grid.Column="1" 
                         Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5" Height="25" VerticalContentAlignment="Center"/>

                <!-- Имя -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Имя:" 
                           Margin="5" VerticalAlignment="Center"/>
                <TextBox x:Name="txtName" Grid.Row="2" Grid.Column="1" 
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5" Height="25" VerticalContentAlignment="Center"/>

                <!-- Отчество -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Отчество:" 
                           Margin="5" VerticalAlignment="Center"/>
                <TextBox x:Name="txtSurname" Grid.Row="3" Grid.Column="1" 
                         Text="{Binding Surname, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5" Height="25" VerticalContentAlignment="Center"/>

                <!-- Телефон -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Телефон:" 
                           Margin="5" VerticalAlignment="Center"/>
                <TextBox x:Name="txtPhone" Grid.Row="4" Grid.Column="1" TextChanged="txtPhone_TextChanged"
                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5" Height="25" VerticalContentAlignment="Center"/>

                <!-- Email -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Email:" 
                           Margin="5" VerticalAlignment="Center"/>
                <TextBox x:Name="txtEmail" Grid.Row="5" Grid.Column="1" 
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5" Height="25" VerticalContentAlignment="Center" PreviewTextInput="txtEmail_PreviewTextInput"/>

                <!-- Доступ к системе -->
                <CheckBox x:Name="chkSystemAccess" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                          Content="Доступ к системе"
                          IsChecked="{Binding HasSystemAccess}"
                          Margin="5" VerticalAlignment="Center"/>

                <!-- Логин -->
                <TextBlock Grid.Row="7" Grid.Column="0" Text="Логин:" 
                           Margin="5" VerticalAlignment="Center"/>
                <TextBox x:Name="txtLogin" Grid.Row="7" Grid.Column="1" 
                         Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5" Height="25" VerticalContentAlignment="Center"
                         IsEnabled="{Binding HasSystemAccess}"/>

                <!-- Пароль (только для добавления) -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Пароль:" 
                           Margin="5" VerticalAlignment="Center"/>
                <PasswordBox x:Name="txtPassword" Grid.Row="8" Grid.Column="1" 
                             Margin="5" Height="25" VerticalContentAlignment="Center"
                             IsEnabled="{Binding HasSystemAccess}" PasswordChanged="txtPassword_PasswordChanged"/>

                <!-- Подтверждение пароля -->
                <TextBlock Grid.Row="9" Grid.Column="0" Text="Подтверждение:" 
                           Margin="5" VerticalAlignment="Center"/>
                <PasswordBox x:Name="txtPasswordConfirm" Grid.Row="9" Grid.Column="1" 
                             Margin="5" Height="25" VerticalContentAlignment="Center"
                             IsEnabled="{Binding HasSystemAccess}" PasswordChanged="txtPassword_PasswordChanged"/>
            </Grid>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="30" 
                    Margin="5" Click="btnSave_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="100" Height="30" 
                    Margin="5" Click="btnDelete_Click" Background="#FFE74C3C" Foreground="White"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="30" 
                    Margin="5" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Page>