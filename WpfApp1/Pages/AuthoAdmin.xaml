<Page x:Class="WpfApp1.Pages.AuthoAdmin"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthoAdmin">


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="80"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="56"/>
            <RowDefinition />
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="2"
                    Grid.ColumnSpan="2" HorizontalAlignment="Right">
            <TextBlock Text="Администратор: "/>
            <TextBlock x:Name="txtFullName"/>
        </StackPanel>

        <!-- Поиск -->
        <TextBox Name="txtSearch" Grid.Row="1" Grid.Column="0"
                 VerticalAlignment="Center" Margin="5,0,5,0"
                 TextChanged="txtSearch_TextChanged"
                 ToolTip="Поиск по имени, фамилии, email или телефону"/>

        <!-- Сортировка -->
        <ComboBox Name="cmbSorting" Grid.Row="1" Grid.Column="1"
                  SelectedIndex="0" VerticalAlignment="Center" Margin="5,0,5,0"
                  SelectionChanged="cmbSorting_SelectionChanged"/>

        <!-- Фильтр -->
        <ComboBox Name="cmbFilter" Grid.Row="1" Grid.Column="2"
                  SelectedIndex="0" VerticalAlignment="Center" Margin="5,0,5,0"
                  SelectionChanged="cmbFilter_SelectionChanged"/>

        <!-- Счетчики -->
        <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="3"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="txtResultAmount"/>
            <TextBlock Text=" из "/>
            <TextBlock x:Name="txtAllAmount"/>
        </StackPanel>

        <!-- Список сотрудников -->
        <ListView Name="LViewEmployees" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" 
                  Margin="5,5,5,5" SelectionChanged="LViewEmployee_SelectionChanged"
                  MouseDoubleClick="LViewEmployees_MouseDoubleClick">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Margin="2"
                            Background="{Binding Background}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>

                            <!-- Иконка сотрудника -->
                            <StackPanel Grid.Column="0" Margin="5" VerticalAlignment="Center">
                                <TextBlock Text="{Binding RoleIcon}" FontSize="24" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Информация о сотруднике -->
                            <StackPanel Grid.Column="1" Margin="5" VerticalAlignment="Center">
                                <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding Position}" FontStyle="Italic"/>
                                <TextBlock Text="{Binding Department}"/>
                            </StackPanel>

                            <!-- Контактная информация -->
                            <StackPanel Grid.Column="2" Margin="5" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding Phone}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding Email}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Дополнительная информация -->
                            <StackPanel Grid.Column="3" Margin="5" VerticalAlignment="Center">
                                <TextBlock Text="{Binding AuthoInfo}" FontSize="10"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Кнопки действий -->
        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" 
                    Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnAdd" Content="Добавить" 
                    Click="btnAdd_Click" Width="150" Margin="5"/>
        </StackPanel>
    </Grid>
</Page>